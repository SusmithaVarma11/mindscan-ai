<!DOCTYPE html>
<html>
<head>
    <title>Mental Health Detection</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <div class="container">
        <h1>Mental Health Signal Detection</h1>

        <form method="POST">
            <textarea name="text" placeholder="Enter social media post..." required></textarea>
            <br><br>
            <button type="submit">Analyze</button>
        </form>

        {% if result %}
            <h2>Prediction: {{ result }}</h2>
        {% endif %}
    </div>
</body>
</html>

